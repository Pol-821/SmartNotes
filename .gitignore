.vs/
.idea/
.vscode/
*.suo
*.userprefs
*swp

# OS
.DS_Store
Thumbs.db

# Node (frontend)
smartnotes-web/node_modules/
smartnotes-web/dist/

# Uploads (user data)
SmartNotes.Api/Uploads/
SmartNotes.Api/wwwroot/uploads/

